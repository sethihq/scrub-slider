{
  "name": "@sethihq/scrub-slider",
  "version": "0.2.1",
  "description": "A slider component with scrub sounds and haptic feedback",
  "author": "sethihq",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sethihq/scrub-slider"
  },
  "homepage": "https://scrub-slider.vercel.app",
  "keywords": [
    "slider",
    "react",
    "radix",
    "haptics",
    "sound",
    "web-audio",
    "component"
  ],
  "main": "./dist/slider.js",
  "module": "./dist/slider.js",
  "types": "./dist/slider.d.mts",
  "exports": {
    ".": {
      "import": "./dist/slider.js",
      "types": "./dist/slider.d.mts"
    },
    "./slider": {
      "import": "./dist/slider.js",
      "types": "./dist/slider.d.mts"
    },
    "./use-haptics": {
      "import": "./dist/use-haptics.js",
      "types": "./dist/use-haptics.d.mts"
    },
    "./use-sound": {
      "import": "./dist/use-sound.js",
      "types": "./dist/use-sound.d.mts"
    },
    "./utils": {
      "import": "./dist/utils.js",
      "types": "./dist/utils.d.mts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pkg": "tsup",
    "start": "next start"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@radix-ui/react-slider": ">=1.0.0",
    "@number-flow/react": ">=0.4.0",
    "web-haptics": ">=0.0.5",
    "clsx": ">=2.0.0",
    "tailwind-merge": ">=2.0.0"
  },
  "devDependencies": {
    "@number-flow/react": "^0.6.0",
    "@radix-ui/react-slider": "^1.3.6",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vercel/analytics": "^2.0.1",
    "calligraph": "^1.4.1",
    "clawd-react": "^0.1.0",
    "clsx": "^2.1.1",
"next": "^16.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "web-haptics": "^0.0.6"
  }
